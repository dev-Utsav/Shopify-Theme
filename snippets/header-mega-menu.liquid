{% comment %}
Renders a megamenu for the header.
{% endcomment %}

<nav class="header__inline-menu">
  <ul class="list-menu list-menu--inline" role="list">
    {%- for link in section.settings.menu.links -%}
      <li>

```
    {%- if link.links != blank -%}

      <header-menu>
        <details id="Details-HeaderMenu-{{ forloop.index }}" class="mega-menu">

          <summary
            id="HeaderMenu-{{ link.handle }}"
            class="header__menu-item list-menu__item link focus-inset"
          >
            <span
              {% if link.child_active %}
              class="header__active-menu-item"
              {% endif %}
            >
              {{ link.title }}
            </span>

            <svg class="icon icon-caret" viewBox="0 0 10 6">
              <path fill-rule="evenodd" clip-rule="evenodd"
                d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z"
                fill="currentColor"/>
            </svg>
          </summary>

          <div
            id="MegaMenu-Content-{{ forloop.index }}"
            class="mega-menu__content gradient motion-reduce global-settings-popup"
            tabindex="-1"
          >

            {% comment %} FIND MATCHING BLOCKS {% endcomment %}
            {% assign promo_block = blank %}
            {% assign custom_block = blank %}

            {% for block in section.blocks %}

              {% if block.type == 'mega_menu_images' %}
                {% assign trigger_handle = block.settings.menu_trigger | handleize %}
                {% assign menu_handle = link.title | handleize %}

                {% if trigger_handle == menu_handle %}
                  {% assign promo_block = block %}
                {% endif %}
              {% endif %}

              {% if block.type == 'custom_mega_menu' %}
                {% assign trigger_menu = block.settings.select_menu.handle %}
                {% assign current_menu = section.settings.menu.handle %}

                {% if trigger_menu == current_menu %}
                  {% assign custom_block = block %}
                {% endif %}
              {% endif %}

            {% endfor %}

            <div class="mega-menu__inner-layout page-width">

              <ul
                class="mega-menu__list grid grid--1-col list-unstyled"
                role="list"
              >

                {%- for childlink in link.links -%}

                  <li class="mega-menu__column">

                    <a
                      href="{{ childlink.url }}"
                      class="mega-menu__link mega-menu__link--level-2 link"
                    >
                      {{ childlink.title }}
                    </a>

                    {% if childlink.links != blank %}
                      <ul class="list-unstyled">
                        {% for grandchildlink in childlink.links %}
                          <li>
                            <a
                              href="{{ grandchildlink.url }}"
                              class="mega-menu__link link"
                            >
                              {{ grandchildlink.title }}
                            </a>
                          </li>
                        {% endfor %}
                      </ul>
                    {% endif %}

                    {% comment %} COLUMN PROMO IMAGE {% endcomment %}
                    {% if promo_block != blank %}

                      {% assign col_index = forloop.index %}
                      {% capture img_setting %}image_{{ col_index }}{% endcapture %}
                      {% capture link_setting %}link_{{ col_index }}{% endcapture %}

                      {% if promo_block.settings[img_setting] != blank %}

                      <div class="mega-menu__promo-image-container">
                        <a href="{{ promo_block.settings[link_setting] }}">

                          <div class="media media--landscape">

                            <img
                              src="{{ promo_block.settings[img_setting] | image_url: width: 600 }}"
                              alt=""
                              loading="lazy"
                              width="600"
                            >

                          </div>

                        </a>
                      </div>

                      {% endif %}

                    {% endif %}

                  </li>

                {%- endfor -%}

              </ul>


              {% comment %} CUSTOM MEGA SECTION {% endcomment %}
              {% if custom_block != blank %}

              <div class="mega-menu-custom">

                {% comment %} {% if custom_block.settings.menu_image != blank %}
                <div class="mega-menu-custom-image">
                  <img
                    src="{{ custom_block.settings.menu_image | image_url: width: 500 }}"
                    alt="{{ custom_block.settings.menu_title }}"
                    loading="lazy"
                  >
                </div>
                {% endif %} {% endcomment %}

                {% if custom_block.settings.menu_collection != blank %}
                <div class="mega-menu-custom-collection">
                  <a href="{{ custom_block.settings.menu_collection.url }}">
                    {{ custom_block.settings.menu_collection.title }}
                  </a>
                </div>
                {% endif %}

              </div>

              {% endif %}

            </div>

          </div>

        </details>
      </header-menu>

    {%- else -%}

      <a
        href="{{ link.url }}"
        class="header__menu-item list-menu__item link link--text focus-inset"
      >
        {{ link.title }}
      </a>

    {%- endif -%}

  </li>
{%- endfor -%}
```

  </ul>
</nav>

<style>

.mega-menu__promo-image-container{
margin-top:2rem;
}

.mega-menu-custom{
margin-top:30px;
text-align:center;
}

.mega-menu-custom-image img{
width:100%;
max-width:260px;
border-radius:6px;
}

.mega-menu-custom-collection a{
display:block;
margin-top:10px;
font-weight:600;
text-decoration:none;
}

</style>
